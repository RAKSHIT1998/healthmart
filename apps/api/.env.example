# ---- Server ----
NODE_ENV=production
PORT=5000
API_BASE_URL=https://buymedicine.store
SITE_URL=https://buymedicine.store
CORS_ORIGINS=https://buymedicine.store

# ---- Database (MongoDB Atlas) ----
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/buymedicines?retryWrites=true&w=majority

# ---- Redis (optional) ----
REDIS_URL=redis://localhost:6379

# ---- JWT ----
JWT_ACCESS_SECRET=replace-with-a-random-64-character-secret-string-for-access-tokens
JWT_REFRESH_SECRET=replace-with-a-different-random-64-character-secret-for-refresh-tokens

# ---- Cloudinary ----
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ---- MSG91 (SMS / OTP) ----
MSG91_AUTH_KEY=
MSG91_SENDER_ID=
MSG91_OTP_TEMPLATE_ID=
MSG91_WHATSAPP_TEMPLATE_ID=
MSG91_WHATSAPP_INVOICE_TEMPLATE_ID=
MSG91_WHATSAPP_DRIVER_ASSIGN_TEMPLATE_ID=
MSG91_WHATSAPP_SALES_ALERT_TEMPLATE_ID=
SALES_TEAM_WHATSAPP_NUMBERS=919999999999,918888888888
WHATSAPP_PROVIDER=msg91
OPENWA_BASE_URL=http://localhost:2785/api
OPENWA_API_KEY=
OPENWA_SESSION_ID=default

# ---- Resend (Email) ----
RESEND_API_KEY=
RESEND_FROM_EMAIL=BuyMedicines.store <orders@buymedicine.store>

# ---- Cashfree (Payments) ----
CASHFREE_APP_ID=
CASHFREE_SECRET_KEY=
CASHFREE_ENV=SANDBOX
CASHFREE_WEBHOOK_SECRET=

# ---- Firebase (Push Notifications) ----
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ---- Google Maps ----
GOOGLE_MAPS_API_KEY=

# ---- Agora (Doctor video/audio consultation) ----
AGORA_APP_ID=
AGORA_APP_CERTIFICATE=

# ---- MARG ERP Integration ----
# csv | webhook | api | disabled
MARG_INTEGRATION_MODE=csv
MARG_SYNC_CRON=*/30 * * * *
MARG_CSV_WATCH_DIR=./marg-sync/incoming
MARG_CSV_PROCESSED_DIR=./marg-sync/processed
MARG_WEBHOOK_SECRET=change-me-marg-webhook-secret
MARG_API_BASE_URL=
MARG_API_KEY=
MARG_BRANCH_CODE=

# ---- Seed data ----
ADMIN_SEED_EMAIL=admin@buymedicine.store
ADMIN_SEED_PASSWORD=ChangeMe@12345

# ---- Next.js build-time vars (set as Railway Build Variables) ----
# These are baked into the JS bundle at docker build time.
NEXT_PUBLIC_API_URL=https://buymedicine.store/api/v1
NEXT_PUBLIC_SITE_URL=https://buymedicine.store
NEXT_PUBLIC_CASHFREE_ENV=PRODUCTION
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
